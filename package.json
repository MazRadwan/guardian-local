{
  "name": "guardian-app",
  "version": "1.0.0",
  "private": true,
  "description": "Guardian: AI-powered healthcare vendor assessment platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "pnpm --filter @guardian/backend db:migrate",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/node": "^22.11.0",
    "chrome-devtools-mcp": "^0.10.1",
    "dotenv": "^16.4.7",
    "drizzle-kit": "latest",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "socket.io-client": "^4.8.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "esbuild", "puppeteer", "sharp"]
  }
}
