{
  "escalate_when": {
    "max_iterations_reached": {
      "enabled": true,
      "description": "Tried maximum number of fix attempts without success"
    },
    "cant_determine_root_cause": {
      "enabled": true,
      "description": "Unable to identify source of bug after analysis"
    },
    "no_viable_strategy": {
      "enabled": true,
      "description": "All potential fix strategies have been tried and failed"
    },
    "breaking_multiple_features": {
      "enabled": true,
      "threshold": 2,
      "description": "Fix breaks 2 or more existing features"
    },
    "performance_degradation": {
      "enabled": true,
      "threshold_percent": 20,
      "description": "Performance drops by more than 20%"
    },
    "security_concern": {
      "enabled": true,
      "description": "Potential security vulnerability detected"
    },
    "architectural_change_required": {
      "enabled": true,
      "description": "Fix requires significant architectural changes"
    },
    "test_suite_timeout": {
      "enabled": true,
      "timeout_ms": 300000,
      "description": "Tests take longer than 5 minutes to run"
    }
  },
  "escalation_format": {
    "include_context": true,
    "include_attempts_history": true,
    "include_failed_approaches": true,
    "include_current_state": true,
    "include_rollback_point": true,
    "suggest_next_steps": true,
    "attach_screenshots": true,
    "attach_logs": true
  },
  "escalation_message_template": {
    "title": "🚨 ESCALATION: {bug_id} - {reason}",
    "sections": [
      "## Problem Summary",
      "## Attempts Made ({iteration} iterations)",
      "## Failed Approaches",
      "## Current State",
      "## Suggested Next Steps",
      "## Evidence & Logs"
    ]
  }
}
