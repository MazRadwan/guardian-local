# Server Configuration
PORT=8000
# CORS_ORIGIN supports comma-separated list for multiple dev ports
# Example: http://localhost:3000,http://localhost:3001,https://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guardian_dev

# JWT Configuration
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_EXPIRES_IN=4h

# Claude API Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Feature Flags
# Set to 'true' to use Claude tool calls for questionnaire generation trigger
# Set to 'false' (default) to use pattern matching (TriggerDetection.ts)
USE_TOOL_BASED_TRIGGER=false
