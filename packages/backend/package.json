{
  "name": "@guardian/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run build:copy-templates",
    "build:copy-templates": "mkdir -p dist/infrastructure/export/templates && cp -r src/infrastructure/export/templates/* dist/infrastructure/export/templates/",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest --testPathIgnorePatterns=e2e-external",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e --testPathIgnorePatterns=e2e-external",
    "test:e2e:external": "jest --testPathPattern=e2e-external",
    "test:all": "jest",
    "test:watch": "jest --watch --testPathIgnorePatterns=e2e",
    "test:watch:unit": "jest --watch --testPathPattern=unit",
    "test:coverage": "jest --coverage --testPathIgnorePatterns=e2e-external",
    "db:generate": "cd ../.. && drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/database/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.35.0",
    "@aws-sdk/client-s3": "^3.948.0",
    "@guardian/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "docx": "9.5.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "latest",
    "exceljs": "4.4.0",
    "express": "^5.1.0",
    "file-type": "^21.1.1",
    "isomorphic-dompurify": "^2.34.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "marked": "^17.0.1",
    "multer": "^2.0.2",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.5",
    "puppeteer": "24.2.0",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/marked": "^6.0.0",
    "@types/multer": "^2.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "latest",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
