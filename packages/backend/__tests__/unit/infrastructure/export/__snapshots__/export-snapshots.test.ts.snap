exports[`Export Snapshot Tests (38.8.2) HTML Template Snapshot should match the rendered HTML snapshot 1`] = `
"<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Guardian Risk Assessment Report</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', Tahoma, sans-serif;
      color: #1f2937;
      line-height: 1.6;
      padding: 40px;
      font-size: 14px;
    }

    /* ===== PAGE BREAK CONTROLS ===== */
    .page-break { page-break-before: always; }
    .avoid-break { page-break-inside: avoid; }
    h1, h2, h3, h4 { page-break-after: avoid; }
    .section { page-break-inside: avoid; }

    /* Keep headers with their content */
    h2 + *, h3 + * { page-break-before: avoid; }

    /* ===== HEADER ===== */
    .header {
      border-bottom: 3px solid #1e3a5f;
      padding-bottom: 20px;
      margin-bottom: 30px;
    }

    .header h1 {
      color: #1e3a5f;
      font-size: 28px;
      margin-bottom: 10px;
    }

    .header .subtitle {
      color: #6b7280;
      font-size: 14px;
    }

    .assessment-id {
      font-family: monospace;
      background: #f3f4f6;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 12px;
    }

    /* ===== SCORE BANNER ===== */
    .score-banner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: linear-gradient(135deg, #f0f4f8 0%, #dbe4ee 100%);
      padding: 24px;
      border-radius: 12px;
      margin-bottom: 30px;
      page-break-inside: avoid;
    }

    .composite-score {
      text-align: center;
    }

    .composite-score .value {
      font-size: 48px;
      font-weight: bold;
      color: #1e3a5f;
    }

    .composite-score .label {
      font-size: 14px;
      color: #6b7280;
    }

    .recommendation {
      padding: 12px 24px;
      border-radius: 24px;
      font-weight: 600;
      font-size: 16px;
    }

    .recommendation.approve { background: #dcfce7; color: #166534; }
    .recommendation.conditional { background: #fef3c7; color: #92400e; }
    .recommendation.decline { background: #fee2e2; color: #991b1b; }
    .recommendation.more_info { background: #dbeafe; color: #1e40af; }

    .overall-risk {
      margin-top: 8px;
      font-size: 14px;
      color: #6b7280;
    }

    .overall-risk strong {
      text-transform: uppercase;
    }

    /* ===== SECTIONS ===== */
    .section {
      margin-bottom: 30px;
    }

    .section h2 {
      font-size: 18px;
      color: #1e3a5f;
      margin-bottom: 12px;
      padding-bottom: 8px;
      border-bottom: 2px solid #e5e7eb;
      page-break-after: avoid;
    }

    /* ===== EXECUTIVE SUMMARY ===== */
    .executive-summary {
      background: #f9fafb;
      padding: 16px;
      border-radius: 8px;
      font-size: 14px;
      border-left: 4px solid #1e3a5f;
    }

    /* ===== KEY FINDINGS ===== */
    .findings-list {
      list-style: none;
    }

    .findings-list li {
      padding: 10px 0;
      padding-left: 24px;
      position: relative;
      font-size: 14px;
      border-bottom: 1px solid #f3f4f6;
    }

    .findings-list li:last-child {
      border-bottom: none;
    }

    .findings-list li::before {
      content: "";
      width: 8px;
      height: 8px;
      background: #f59e0b;
      border-radius: 50%;
      position: absolute;
      left: 0;
      top: 14px;
    }

    /* ===== DIMENSION TABLE ===== */
    .dimension-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
      page-break-inside: avoid;
    }

    .dimension-table th {
      text-align: left;
      padding: 12px;
      background: #1e3a5f;
      color: white;
      font-weight: 600;
    }

    .dimension-table th:first-child {
      border-radius: 8px 0 0 0;
    }

    .dimension-table th:last-child {
      border-radius: 0 8px 0 0;
    }

    .dimension-table td {
      padding: 12px;
      border-bottom: 1px solid #e5e7eb;
    }

    .dimension-table tr:nth-child(even) {
      background: #f9fafb;
    }

    .dimension-table tr:last-child td:first-child {
      border-radius: 0 0 0 8px;
    }

    .dimension-table tr:last-child td:last-child {
      border-radius: 0 0 8px 0;
    }

    /* ===== SCORE BARS ===== */
    .score-bar {
      width: 100px;
      height: 8px;
      background: #e5e7eb;
      border-radius: 4px;
      overflow: hidden;
    }

    .score-bar-fill {
      height: 100%;
      border-radius: 4px;
    }

    .risk-low { background: #22c55e; }
    .risk-medium { background: #f59e0b; }
    .risk-high { background: #f97316; }
    .risk-critical { background: #ef4444; }

    /* ===== CONFIDENCE BADGES ===== */
    .confidence-badge {
      padding: 2px 8px;
      border-radius: 8px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      display: inline-block;
    }

    .confidence-badge.high { background: #dcfce7; color: #166534; }
    .confidence-badge.medium { background: #fef3c7; color: #92400e; }
    .confidence-badge.low { background: #fee2e2; color: #991b1b; }

    .iso-ref-count {
      font-size: 12px;
      color: #6b7280;
    }

    .no-data {
      color: #d1d5db;
      font-style: italic;
    }

    /* ===== RISK BADGES ===== */
    .risk-badge {
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      display: inline-block;
    }

    .risk-badge.low { background: #dcfce7; color: #166534; }
    .risk-badge.medium { background: #fef3c7; color: #92400e; }
    .risk-badge.high { background: #ffedd5; color: #c2410c; }
    .risk-badge.critical { background: #fee2e2; color: #991b1b; }

    /* ===== ISO ALIGNMENT SECTION ===== */
    .iso-alignment-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      page-break-inside: avoid;
    }

    .iso-alignment-table th {
      text-align: left;
      padding: 10px 12px;
      background: #374151;
      color: white;
      font-weight: 600;
    }

    .iso-alignment-table td {
      padding: 10px 12px;
      border-bottom: 1px solid #e5e7eb;
    }

    .iso-status {
      padding: 2px 8px;
      border-radius: 8px;
      font-size: 11px;
      font-weight: 600;
      display: inline-block;
    }

    .iso-status.aligned { background: #dcfce7; color: #166534; }
    .iso-status.partial { background: #fef3c7; color: #92400e; }
    .iso-status.not_evidenced { background: #fee2e2; color: #991b1b; }
    .iso-status.not_applicable { background: #f3f4f6; color: #6b7280; }

    .framework-label {
      font-size: 11px;
      color: #6b7280;
      font-style: italic;
    }

    /* ===== GUARDIAN-NATIVE LABEL ===== */
    .guardian-native-label {
      display: block;
      font-size: 10px;
      color: #1e3a5f;
      font-style: italic;
      margin-top: 2px;
    }

    .iso-disclaimer {
      margin-top: 12px;
      font-size: 11px;
      color: #9ca3af;
      font-style: italic;
      border-top: 1px solid #e5e7eb;
      padding-top: 8px;
    }

    /* ===== NARRATIVE CONTENT STYLING ===== */
    .narrative {
      line-height: 1.7;
    }

    .narrative h1 {
      font-size: 22px;
      color: #1e3a5f;
      margin-top: 30px;
      margin-bottom: 16px;
      padding-bottom: 8px;
      border-bottom: 2px solid #1e3a5f;
      page-break-after: avoid;
    }

    .narrative h2 {
      font-size: 18px;
      color: #374151;
      margin-top: 28px;
      margin-bottom: 14px;
      padding-bottom: 6px;
      border-bottom: 1px solid #e5e7eb;
      page-break-after: avoid;
    }

    .narrative h3 {
      font-size: 15px;
      color: #4b5563;
      margin-top: 20px;
      margin-bottom: 10px;
      page-break-after: avoid;
    }

    .narrative h4 {
      font-size: 14px;
      color: #6b7280;
      margin-top: 16px;
      margin-bottom: 8px;
      font-weight: 600;
    }

    .narrative p {
      margin-bottom: 12px;
      text-align: justify;
    }

    .narrative strong {
      color: #1f2937;
      font-weight: 600;
    }

    .narrative em {
      font-style: italic;
      color: #4b5563;
    }

    /* Narrative lists */
    .narrative ul, .narrative ol {
      margin-bottom: 16px;
      padding-left: 24px;
    }

    .narrative ul {
      list-style: none;
    }

    .narrative ul li {
      position: relative;
      padding-left: 16px;
      margin-bottom: 8px;
    }

    .narrative ul li::before {
      content: "";
      width: 6px;
      height: 6px;
      background: #1e3a5f;
      border-radius: 50%;
      position: absolute;
      left: 0;
      top: 8px;
    }

    .narrative ol li {
      margin-bottom: 8px;
    }

    /* Narrative tables */
    .narrative table {
      width: 100%;
      border-collapse: collapse;
      margin: 16px 0;
      font-size: 13px;
      page-break-inside: avoid;
    }

    .narrative table th {
      background: #f3f4f6;
      padding: 10px 12px;
      text-align: left;
      font-weight: 600;
      border-bottom: 2px solid #e5e7eb;
    }

    .narrative table td {
      padding: 10px 12px;
      border-bottom: 1px solid #e5e7eb;
    }

    .narrative table tr:nth-child(even) {
      background: #f9fafb;
    }

    /* Horizontal rules in narrative */
    .narrative hr {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 24px 0;
    }

    /* Blockquotes for emphasis */
    .narrative blockquote {
      border-left: 4px solid #1e3a5f;
      background: #f0f4f8;
      padding: 12px 16px;
      margin: 16px 0;
      font-style: italic;
    }

    /* Code/monospace for IDs, references */
    .narrative code {
      font-family: monospace;
      background: #f3f4f6;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 12px;
    }

    /* Risk level highlighting in text */
    .narrative .risk-high-text,
    .narrative strong:contains('HIGH'),
    .narrative strong:contains('CRITICAL') {
      color: #dc2626;
    }

    .narrative .risk-medium-text {
      color: #d97706;
    }

    .narrative .risk-low-text {
      color: #16a34a;
    }

    /* Dimension sections - keep together */
    .narrative h2 + p,
    .narrative h2 + ul,
    .narrative h2 + ol,
    .narrative h2 + table {
      page-break-before: avoid;
    }

    /* Priority callouts */
    .narrative strong:first-child {
      display: inline-block;
    }

    /* ===== FOOTER ===== */
    .footer {
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e5e7eb;
      font-size: 12px;
      color: #9ca3af;
      text-align: center;
    }

    /* ===== PRINT OPTIMIZATIONS ===== */
    @media print {
      body {
        padding: 20px;
      }

      .page-break {
        page-break-before: always;
      }

      .section {
        page-break-inside: avoid;
      }

      h2, h3, h4 {
        page-break-after: avoid;
      }

      .dimension-table,
      .narrative table {
        page-break-inside: avoid;
      }

      .score-banner {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      .risk-badge,
      .recommendation {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
    }
  </style>
</head>
