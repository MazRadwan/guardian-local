@startuml Guardian Infrastructure Layer
allowmixing
top to bottom direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam class {
    BackgroundColor White
    BorderColor Black
}

package "HTTP / Controllers" {
    class AuthController {
        -authService: AuthService
        +POST /auth/login
        +POST /auth/register
        +POST /auth/logout
    }

    class AssessmentController {
        -assessmentService: AssessmentService
        +POST /assessments
        +GET /assessments/:id
        +GET /assessments
        +PATCH /assessments/:id
    }

    class VendorController {
        -vendorService: VendorService
        +POST /vendors
        +GET /vendors
        +GET /vendors/:id
        +PATCH /vendors/:id
    }

    class ExportController {
        -exportService: ExportService
        +GET /export/:assessmentId/pdf
        +GET /export/:assessmentId/word
        +GET /export/:assessmentId/excel
    }

    class ScoringExportController {
        -scoringExportService: ScoringExportService
        +GET /scoring/:assessmentId/pdf
        +GET /scoring/:assessmentId/word
    }
}

package "WebSocket (Epic 28 Modular)" {
    class ChatServer {
        -handlers: Handler[]
        -modeStrategies: ModeStrategyFactory
        +initialize(io)
        +registerHandlers()
    }

    package "Handlers" {
        class ConnectionHandler {
            +handleConnection(socket)
            +handleDisconnect(socket)
            +emitConnectionReady()
        }

        class MessageHandler {
            -streamingHandler: StreamingHandler
            -toolUseRegistry: ToolUseRegistry
            +handleSendMessage(data)
            +streamResponse(callback)
        }

        class ConversationHandler {
            +handleStartNew()
            +handleGetHistory()
            +handleGetConversations()
            +handleDeleteConversation()
        }

        class ModeSwitchHandler {
            +handleSwitchMode(mode)
            +emitModeGuidance()
        }

        class QuestionnaireHandler {
            +handleGenerateQuestionnaire()
            +handleGetExportStatus()
            +emitExportReady()
        }

        class ScoringHandler {
            +handleScoringFlow()
            +handleVendorClarification()
            +emitScoringProgress()
        }
    }

    package "Mode Strategies" {
        interface IModeStrategy {
            +buildSystemPrompt(): string
            +getTools(): Tool[]
            +validateContext(): boolean
        }

        class ConsultModeStrategy
        class AssessmentModeStrategy
        class ScoringModeStrategy
    }

    package "Context Builders" {
        class ConversationContextBuilder {
            +buildContext(conversation)
            +includeHistory(messages)
        }

        class FileContextBuilder {
            +buildFileContext(files)
            +buildWithImages(conversationId): FileContextResult
            +includeIntakeContext()
        }
    }

    package "Utilities" {
        class StreamingHandler {
            +stream(response, callback)
            +handleChunk(chunk)
        }

        class ToolUseRegistry {
            +registerToolUse(block)
            +getActiveTools()
        }

        class RateLimiter {
            +checkLimit(userId): boolean
            +resetLimit(userId): void
        }
    }
}

package "AI / Claude Integration" {
    class ClaudeClient {
        -client: Anthropic
        -promptCache: PromptCacheManager
        +chat(messages): Response
        +streamChat(messages, onChunk): void
        +streamMessage(messages, options, imageBlocks?): AsyncGenerator
        +useTools(messages, tools): ToolResult
    }

    class PromptCacheManager {
        -cache: Map<string, CachedPrompt>
        +get(key): string
        +set(key, prompt): void
    }

    class VisionContentBuilder {
        -imageCache: Map<string, ImageContentBlock>
        +buildImageContent(file, conversationId?): ImageContentBlock
        +isImageFile(mimeType): boolean
        +clearConversationCache(conversationId): void
    }

    class DocumentParserService {
        +parseDocument(file): ParsedContent
        +extractText(file): string
    }

    class ScoringPromptBuilder {
        +buildPrompt(assessment, responses): string
        +buildSystemPrompt(): string
    }

    class ExportNarrativeGenerator {
        +generateNarrative(result): string
        +claimGeneration(resultId): boolean
    }
}

package "Database / Repositories" {
    class DrizzleUserRepository {
        +findById(id): User
        +findByEmail(email): User
        +save(user): User
    }

    class DrizzleConversationRepository {
        +findById(id): Conversation
        +findByUserId(userId): Conversation[]
        +save(conversation): Conversation
        +updateTitle(id, title): void
    }

    class DrizzleAssessmentRepository {
        +findById(id): Assessment
        +findByVendorId(vendorId): Assessment[]
        +save(assessment): Assessment
    }

    class DrizzleMessageRepository {
        +findByConversationId(id): Message[]
        +save(message): Message
    }

    class DrizzleResponseRepository {
        +findByAssessmentId(id): Response[]
        +saveBatch(responses): void
        +deleteOrphans(cutoff): number
    }

    class DrizzleDimensionScoreRepository {
        +findByAssessmentId(id): DimensionScore[]
        +saveBatch(scores): void
    }

    class DrizzleAssessmentResultRepository {
        +findByAssessmentId(id): AssessmentResult
        +save(result): AssessmentResult
        +claimNarrativeGeneration(id): boolean
    }

    class DrizzleFileRepository {
        +findByConversationId(id): File[]
        +save(file): File
    }
}

package "Export" {
    class PDFExporter {
        +generate(data): Buffer
    }

    class WordExporter {
        +generate(data): Buffer
    }

    class ExcelExporter {
        +generate(data): Buffer
    }

    class ScoringPDFExporter {
        +generate(result): Buffer
        +renderDimensionScores(scores)
        +renderExecutiveSummary(summary)
    }

    class ScoringWordExporter {
        +generate(result): Buffer
    }
}

package "Storage" {
    class LocalFileStorage {
        -basePath: string
        +save(file, path): string
        +retrieve(path): Buffer
        +delete(path): void
    }
}

package "Auth" {
    class JWTProvider {
        -secret: string
        +sign(payload): string
        +verify(token): TokenPayload
    }
}

database "PostgreSQL" as DB

' ChatServer -> Handlers
ChatServer --> ConnectionHandler
ChatServer --> MessageHandler
ChatServer --> ConversationHandler
ChatServer --> ModeSwitchHandler
ChatServer --> QuestionnaireHandler
ChatServer --> ScoringHandler

' Handlers -> Mode Strategies
MessageHandler --> IModeStrategy
ConsultModeStrategy ..|> IModeStrategy
AssessmentModeStrategy ..|> IModeStrategy
ScoringModeStrategy ..|> IModeStrategy

' Handlers -> Context Builders
MessageHandler --> ConversationContextBuilder
MessageHandler --> FileContextBuilder

' FileContextBuilder -> VisionContentBuilder (Epic 30)
FileContextBuilder --> VisionContentBuilder

' ConnectionHandler -> VisionContentBuilder (cache cleanup on disconnect)
ConnectionHandler --> VisionContentBuilder

' Handlers -> Utilities
MessageHandler --> StreamingHandler
MessageHandler --> ToolUseRegistry
ChatServer --> RateLimiter

' AI components
MessageHandler --> ClaudeClient
ClaudeClient --> PromptCacheManager
VisionContentBuilder --> LocalFileStorage
ScoringHandler --> ScoringPromptBuilder
ExportNarrativeGenerator --> ClaudeClient

' Repositories -> DB
DrizzleUserRepository --> DB
DrizzleConversationRepository --> DB
DrizzleAssessmentRepository --> DB
DrizzleMessageRepository --> DB
DrizzleResponseRepository --> DB
DrizzleDimensionScoreRepository --> DB
DrizzleAssessmentResultRepository --> DB
DrizzleFileRepository --> DB

' Controllers -> Auth
AuthController ..> JWTProvider

@enduml
