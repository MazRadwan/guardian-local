@startuml Guardian Infrastructure Layer
allowmixing
top to bottom direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam class {
    BackgroundColor White
    BorderColor Black
}

package "HTTP / Controllers" {
    class AuthController {
        -authService: AuthService
        +POST /auth/login
        +POST /auth/register
        +POST /auth/logout
    }

    class AssessmentController {
        -assessmentService: AssessmentService
        +POST /assessments
        +GET /assessments/:id
        +GET /assessments
        +PATCH /assessments/:id
    }

    class VendorController {
        -vendorService: VendorService
        +POST /vendors
        +GET /vendors
        +GET /vendors/:id
        +PATCH /vendors/:id
    }

    class ExportController {
        -exportService: ExportService
        +GET /export/:assessmentId/pdf
        +GET /export/:assessmentId/word
        +GET /export/:assessmentId/excel
    }

    class ScoringExportController {
        -scoringExportService: ScoringExportService
        +GET /scoring/:assessmentId/pdf
        +GET /scoring/:assessmentId/word
        +GET /scoring/:assessmentId/excel
    }
}

package "WebSocket" {
    class ChatServer {
        -handlers: Handler[]
        +initialize(io)
        +registerHandlers()
    }

    package "Handlers" {
        class ConnectionHandler {
            +handleConnection(socket)
            +handleDisconnect(socket)
            +emitConnectionReady()
        }

        class ConversationHandler {
            +handleStartNew()
            +handleGetHistory()
            +handleGetConversations()
            +handleDeleteConversation()
        }

        class ModeSwitchHandler {
            +handleSwitchMode(mode)
            +emitModeGuidance()
        }

        class QuestionnaireHandler {
            +handleGenerateQuestionnaire()
            +handleGetExportStatus()
            +emitExportReady()
        }

        class ScoringHandler {
            +handleScoringFlow()
            +handleVendorClarification()
            +emitScoringProgress()
        }

        class ScoringPostProcessor {
            +handlePostScoring()
            +generateNarrative()
            +updateTitle()
            +emitExportReady()
        }

        class ModeRouter {
            +getModeConfig(mode): ModeConfig
        }
    }

    package "Send Message Pipeline (Epic 36)" {
        class SendMessageOrchestrator {
            +execute(data): void
        }

        class SendMessageValidator {
            +validate(payload): ValidationResult
        }

        class ClaudeStreamingService {
            +stream(messages, options): void
        }

        class ConsultToolLoopService {
            +executeToolLoop(max: 3): void
        }

        class TitleUpdateService {
            +updateTitle(conversationId): void
        }

        class BackgroundEnrichmentService {
            +enrichFiles(conversationId): void
        }
    }

    package "Context Builders" {
        class ConversationContextBuilder {
            +buildContext(conversation)
            +includeHistory(messages)
        }

        class FileContextBuilder {
            +buildFileContext(files)
            +buildWithImages(conversationId): FileContextResult
            +includeIntakeContext()
        }
    }

    package "Utilities" {
        class StreamingHandler {
            +stream(response, callback)
        }

        class ToolUseRegistry {
            +registerToolUse(block)
            +getActiveTools()
        }

        class RateLimiter {
            +checkLimit(userId): boolean
        }
    }
}

package "Extraction Infrastructure (Epic 31/39)" {
    class BackgroundExtractor {
        +processFile(file): void
    }

    class TextExtractionService {
        +extract(file): string
    }

    class ExtractionRoutingService {
        +route(document): ExtractionResult
    }

    class RegexResponseExtractor {
        +extract(text): Response[]
    }

    class ExtractionConfidenceCalculator {
        +calculate(text): ConfidenceScore
    }
}

package "AI / Claude Integration" {
    class ClaudeClient {
        <<facade>>
        implements IClaudeClient, IVisionClient, ILLMClient
    }

    class ClaudeClientBase {
        -client: Anthropic
        +retryWithBackoff()
        +handleError()
    }

    class ClaudeStreamClient {
        +streamMessage(msgs, opts): AsyncGenerator
    }

    class ClaudeTextClient {
        +sendMessage(msgs, opts): Response
    }

    class ClaudeVisionClient {
        +analyzeImage(file): VisionResult
    }

    class PromptCacheManager {
        -cache: Map<string, CachedPrompt>
        +get(key): string
        +set(key, prompt): void
    }

    class VisionContentBuilder {
        -imageCache: Map<string, ImageContentBlock>
        +buildImageContent(file): ImageContentBlock
        +clearConversationCache(id): void
    }

    class DocumentParserService {
        +parseDocument(file): ParsedContent
    }

    class ScoringPromptBuilder {
        +buildPrompt(assessment, responses, isoControls): string
    }

    class ExportNarrativeGenerator {
        +generateNarrative(result): string
    }

    class JinaClient {
        +search(query): SearchResult[]
        +readUrl(url): string
    }
}

package "Database / Repositories" {
    class DrizzleUserRepository
    class DrizzleConversationRepository
    class DrizzleAssessmentRepository
    class DrizzleMessageRepository
    class DrizzleResponseRepository
    class DrizzleDimensionScoreRepository
    class DrizzleAssessmentResultRepository
    class DrizzleFileRepository

    package "ISO Compliance Repos (Epic 37)" {
        class DrizzleComplianceFrameworkRepository
        class DrizzleFrameworkControlRepository
        class DrizzleDimensionControlMappingRepository
        class DrizzleInterpretiveCriteriaRepository
    }
}

package "Export" {
    class PDFExporter
    class WordExporter
    class ExcelExporter

    class ScoringPDFExporter {
        +renderDimensionScores(scores)
        +renderISOConfidence(badges)
    }

    class ScoringWordExporter {
        +generate(result): Buffer
    }

    class ScoringExcelExporter {
        +generate(result): Buffer
        +renderISOControlMapping(mappings)
    }
}

package "Storage" {
    class LocalFileStorage
}

package "Auth" {
    class JWTProvider
}

database "PostgreSQL" as DB

' ChatServer -> Handlers
ChatServer --> ConnectionHandler
ChatServer --> ConversationHandler
ChatServer --> ModeSwitchHandler
ChatServer --> QuestionnaireHandler
ChatServer --> ScoringHandler
ChatServer --> SendMessageOrchestrator

' Send Message Pipeline
SendMessageOrchestrator --> SendMessageValidator
SendMessageOrchestrator --> ClaudeStreamingService
SendMessageOrchestrator --> ConversationContextBuilder
SendMessageOrchestrator --> FileContextBuilder
SendMessageOrchestrator --> TitleUpdateService
SendMessageOrchestrator --> BackgroundEnrichmentService
SendMessageOrchestrator --> ModeRouter

ClaudeStreamingService --> ConsultToolLoopService
ClaudeStreamingService --> ClaudeClient
ConsultToolLoopService --> ToolUseRegistry

' Scoring delegation
ScoringHandler --> ScoringPostProcessor

' Handlers -> Context Builders
FileContextBuilder --> VisionContentBuilder
ConnectionHandler --> VisionContentBuilder

' Handlers -> Utilities
QuestionnaireHandler --> StreamingHandler
ChatServer --> RateLimiter

' ClaudeClient decomposition
ClaudeClient --> ClaudeClientBase
ClaudeStreamClient --|> ClaudeClientBase
ClaudeTextClient --|> ClaudeClientBase
ClaudeVisionClient --|> ClaudeClientBase

' AI components
PromptCacheManager --> ClaudeClient
ScoringPromptBuilder --> JinaClient
ExportNarrativeGenerator --> ClaudeClient

' Extraction
ExtractionRoutingService --> RegexResponseExtractor
ExtractionRoutingService --> ExtractionConfidenceCalculator
BackgroundExtractor --> TextExtractionService

' Repositories -> DB
DrizzleUserRepository --> DB
DrizzleConversationRepository --> DB
DrizzleAssessmentRepository --> DB
DrizzleMessageRepository --> DB
DrizzleResponseRepository --> DB
DrizzleDimensionScoreRepository --> DB
DrizzleAssessmentResultRepository --> DB
DrizzleFileRepository --> DB
DrizzleComplianceFrameworkRepository --> DB
DrizzleFrameworkControlRepository --> DB
DrizzleDimensionControlMappingRepository --> DB
DrizzleInterpretiveCriteriaRepository --> DB

' Controllers -> Auth
AuthController ..> JWTProvider

@enduml
