@startuml Guardian Domain Model
top to bottom direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam class {
    BackgroundColor White
    BorderColor Black
}

package "Entities" {
    class User {
        +id: string
        +email: Email
        +name: string
        +role: UserRole
    }

    class Vendor {
        +id: string
        +name: VendorName
        +industry: string
        +website: string
    }

    class Assessment {
        +id: string
        +vendorId: string
        +assessmentType: AssessmentType
        +status: AssessmentStatus
        +solutionName: string
    }

    class Conversation {
        +id: string
        +userId: string
        +assessmentId: string
        +mode: ConversationMode
        +status: ConversationStatus
        +title: string
        +titleManuallyEdited: boolean
    }

    class Message {
        +id: string
        +conversationId: string
        +role: MessageRole
        +content: MessageContent
        +attachments: MessageAttachment[]
    }

    class Question {
        +id: string
        +assessmentId: string
        +sectionName: string
        +questionText: string
        +questionType: QuestionType
    }

    class File {
        +id: string
        +conversationId: string
        +filename: string
        +mimeType: string
        +intakeContext: IntakeDocumentContext
    }
}

package "Value Objects" {
    class Email {
        -value: string
        +getValue(): string
    }

    class VendorName {
        -value: string
        +getValue(): string
    }

    class AssessmentStatus {
        -value: AssessmentStatusValue
        +canTransitionTo(): boolean
        +isScored(): boolean
    }

    class AssessmentType {
        -value: AssessmentTypeValue
        +isQuick(): boolean
        +isComprehensive(): boolean
        +isCategoryFocused(): boolean
    }

    class ConversationMode {
        <<enumeration>>
        consult
        assessment
        scoring
    }
}

package "Scoring Domain (Epic 39/40)" {
    class Response {
        +id: string
        +assessmentId: string
        +batchId: string
        +sectionNumber: number
        +questionNumber: number
        +responseText: string
        +confidence: number
    }

    class DimensionScore {
        +id: string
        +assessmentId: string
        +batchId: string
        +dimension: RiskDimension
        +score: number
        +riskRating: RiskRating
        +findings: DimensionFindings
    }

    class AssessmentResult {
        +id: string
        +assessmentId: string
        +batchId: string
        +compositeScore: number
        +recommendation: Recommendation
        +overallRiskRating: RiskRating
        +narrativeReport: string
        +narrativeStatus: NarrativeStatus
    }

    interface ScoringCompletePayload {
        +compositeScore: number
        +recommendation: Recommendation
        +overallRiskRating: RiskRating
        +dimensionScores: DimensionScoreData[]
    }

    interface DimensionScoreData {
        +dimension: RiskDimension
        +score: number
        +riskRating: RiskRating
    }

    class ScoringPayloadValidator {
        +validate(): ValidationResult
    }

    class ScoringPayloadReconciler {
        +reconcilePayload(): ReconciliationResult
        ---
        Epic 40: Auto-corrects Claude arithmetic
        (dimension sums, composite weighted avg,
        recommendation from disqualifiers)
    }

    class SubScoreValidator {
        +validate(): SubScoreValidationResult
        ---
        Validates sub-score names,
        maxScore, sum invariants
    }

    class CompositeScoreValidator {
        +validate(): CompositeValidationResult
        ---
        Validates composite matches
        weighted average of dimensions
    }

    class SubScoreRules {
        +SUB_SCORE_RULES: Map
        +getExpectedMaxTotal(): number
        +getValidSubScoreNames(): Set
        ---
        10-dimension sub-score definitions
    }

    class Rubric {
        +RUBRIC_VERSION: "guardian-v1.1"
        +DIMENSION_WEIGHTS: Map<SolutionType, Map>
        +RISK_THRESHOLDS: Map
        +RECOMMENDATION_THRESHOLDS: Map
        +DISQUALIFYING_FACTORS: Map
        +DISQUALIFIER_TIER: Map
        ---
        Weights per solution type:
        clinical_ai, administrative_ai,
        patient_facing
    }

    enum RiskDimension {
        clinical_risk
        privacy_risk
        security_risk
        operational_risk
        integration_risk
        vendor_risk
        regulatory_risk
        financial_risk
        change_management_risk
        data_governance_risk
    }

    enum Recommendation {
        approve
        conditional
        decline
        more_info
    }

    enum SolutionType {
        clinical_ai
        administrative_ai
        patient_facing
    }

    enum DisqualifierTier {
        hard_decline
        remediable_blocker
    }
}

package "Compliance Domain (ISO 27001, Epic 37)" {
    class ComplianceFramework {
        +id: string
        +name: string
        +description: string
        +status: FrameworkStatus
    }

    class FrameworkVersion {
        +id: string
        +frameworkId: string
        +version: string
        +effectiveDate: Date
    }

    class FrameworkControl {
        +id: string
        +versionId: string
        +controlId: string
        +title: string
        +description: string
    }

    class InterpretiveCriteria {
        +id: string
        +controlId: string
        +interpretation: string
        +reviewStatus: ReviewStatus
    }

    class DimensionControlMapping {
        +id: string
        +dimension: RiskDimension
        +controlId: string
        +relevanceWeight: number
    }
}

' Relationships
User "1" --> "*" Conversation : creates
Vendor "1" --> "*" Assessment : has
Assessment "1" --> "*" Question : contains
Assessment "1" --> "*" Response : has
Assessment "1" --> "*" DimensionScore : has
Assessment "1" --> "0..1" AssessmentResult : has
Assessment "1" --> "1" Vendor
Conversation "1" --> "*" Message : contains
Conversation "1" --> "*" File : has
Conversation "*" --> "0..1" Assessment : linked to
Assessment --> AssessmentStatus : has
Assessment --> AssessmentType : has
Conversation --> ConversationMode : has
Vendor --> VendorName : has
User --> Email : has
ScoringCompletePayload --> "*" DimensionScoreData : contains
DimensionScore --> RiskDimension : has
AssessmentResult --> Recommendation : has
Rubric --> SolutionType : weights per
Rubric --> DisqualifierTier : categorizes
ScoringPayloadReconciler --> SubScoreRules : uses
ScoringPayloadReconciler --> Rubric : uses
ScoringPayloadValidator --> SubScoreValidator : delegates
ScoringPayloadValidator --> CompositeScoreValidator : delegates
SubScoreValidator --> SubScoreRules : uses
CompositeScoreValidator --> Rubric : uses

' Compliance relationships
ComplianceFramework "1" --> "*" FrameworkVersion : has
FrameworkVersion "1" --> "*" FrameworkControl : contains
FrameworkControl "1" --> "0..1" InterpretiveCriteria : interpreted by
DimensionControlMapping --> RiskDimension : maps
DimensionControlMapping --> FrameworkControl : maps to

@enduml
