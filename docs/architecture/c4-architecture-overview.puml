@startuml Guardian Architecture Overview
allowmixing
top to bottom direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam class {
    BackgroundColor White
    BorderColor Black
}
skinparam package {
    BackgroundColor<<http>> #E8F4FD
    BackgroundColor<<websocket>> #FDE8E8
    BackgroundColor<<service>> #E8FDE8
    BackgroundColor<<domain>> #FDF8E8
    BackgroundColor<<repo>> #F0E8FD
    BackgroundColor<<infra>> #E8E8E8
}

package "HTTP Layer" <<http>> {
    class AuthController {
        +login()
        +register()
        +logout()
    }

    class AssessmentController {
        +create()
        +getById()
        +list()
    }

    class ExportController {
        +exportPDF()
        +exportWord()
        +exportExcel()
    }

    class VendorController {
        +create()
        +update()
        +list()
    }

    class ScoringExportController {
        +exportScoringPDF()
        +exportScoringWord()
    }
}

package "WebSocket Layer (Epic 28)" <<websocket>> {
    class ChatServer {
        +initialize()
        +registerHandlers()
    }

    class Handlers {
        ConnectionHandler
        MessageHandler
        ConversationHandler
        ModeSwitchHandler
        QuestionnaireHandler
        ScoringHandler
    }

    class ModeStrategies {
        ConsultModeStrategy
        AssessmentModeStrategy
        ScoringModeStrategy
    }
}

package "Application Services" <<service>> {
    class AuthService {
        +authenticate()
        +createUser()
        +validateToken()
    }

    class ConversationService {
        +create()
        +sendMessage()
        +getHistory()
        +updateTitle()
    }

    class AssessmentService {
        +create()
        +updateStatus()
        +markScored()
    }

    class QuestionnaireGenerationService {
        +generate()
        +parseQuestions()
    }

    class QuestionnaireReadyService {
        +checkReadiness()
        +getVendorContext()
    }

    class ScoringService {
        +scoreAssessment()
        +validatePayload()
        +persistResults()
    }

    class ScoringExportService {
        +exportToPDF()
        +exportToWord()
    }

    class ExportService {
        +exportToPDF()
        +exportToWord()
        +exportToExcel()
    }

    class TitleGenerationService {
        +generateTitle()
    }
}

package "Domain Entities" <<domain>> {
    class User
    class Vendor
    class Assessment
    class Conversation
    class Message
    class Question
    class Response
    class DimensionScore
    class AssessmentResult
}

package "Repositories" <<repo>> {
    class UserRepository
    class VendorRepository
    class AssessmentRepository
    class ConversationRepository
    class MessageRepository
    class QuestionRepository
    class FileRepository
    class ResponseRepository
    class DimensionScoreRepository
    class AssessmentResultRepository
}

package "Infrastructure" <<infra>> {
    class ClaudeClient {
        +chat()
        +streamResponse()
        +streamMessage(imageBlocks?)
        +useTools()
    }

    class PromptCacheManager {
        +getCachedPrompt()
        +invalidate()
    }

    class VisionContentBuilder {
        +buildImageContent()
        +isImageFile()
        +clearConversationCache()
    }

    class StreamingHandler {
        +stream()
        +handleChunk()
    }

    class ToolUseRegistry {
        +registerToolUse()
        +getActiveTools()
    }

    class PDFExporter {
        +generate()
    }

    class WordExporter {
        +generate()
    }

    class ScoringPDFExporter {
        +generate()
    }

    class LocalFileStorage {
        +save()
        +retrieve()
    }

    class JWTProvider {
        +sign()
        +verify()
    }
}

database "PostgreSQL" as DB {
}

' HTTP Layer -> Services
AuthController --> AuthService
AssessmentController --> AssessmentService
ExportController --> ExportService
VendorController --> VendorService
ScoringExportController --> ScoringExportService

' WebSocket -> Handlers -> Services
ChatServer --> Handlers
Handlers --> ModeStrategies
Handlers --> ConversationService
Handlers --> QuestionnaireGenerationService
Handlers --> QuestionnaireReadyService
Handlers --> ScoringService

' Services -> Services
ConversationService --> AssessmentService
ConversationService --> TitleGenerationService
QuestionnaireGenerationService --> AssessmentService
QuestionnaireReadyService --> AssessmentService
QuestionnaireReadyService --> VendorService
ScoringService --> AssessmentService
ScoringExportService --> ScoringService

' Services -> Repositories
AuthService --> UserRepository
ConversationService --> ConversationRepository
ConversationService --> MessageRepository
AssessmentService --> AssessmentRepository
AssessmentService --> VendorRepository
QuestionnaireGenerationService --> QuestionRepository
ScoringService --> ResponseRepository
ScoringService --> DimensionScoreRepository
ScoringService --> AssessmentResultRepository
ExportService --> QuestionRepository

' Services -> Infrastructure
AuthService --> JWTProvider
Handlers --> ClaudeClient
Handlers --> StreamingHandler
Handlers --> ToolUseRegistry
Handlers --> VisionContentBuilder
TitleGenerationService --> ClaudeClient
QuestionnaireGenerationService --> ClaudeClient
ScoringService --> ClaudeClient
ClaudeClient --> PromptCacheManager
VisionContentBuilder --> LocalFileStorage
ExportService --> PDFExporter
ExportService --> WordExporter
ExportService --> LocalFileStorage
ScoringExportService --> ScoringPDFExporter

' Repositories -> Database
UserRepository --> DB
VendorRepository --> DB
AssessmentRepository --> DB
ConversationRepository --> DB
MessageRepository --> DB
QuestionRepository --> DB
FileRepository --> DB
ResponseRepository --> DB
DimensionScoreRepository --> DB
AssessmentResultRepository --> DB

' Repositories use Domain Entities
UserRepository ..> User : manages
VendorRepository ..> Vendor : manages
AssessmentRepository ..> Assessment : manages
ConversationRepository ..> Conversation : manages
MessageRepository ..> Message : manages
QuestionRepository ..> Question : manages
ResponseRepository ..> Response : manages
DimensionScoreRepository ..> DimensionScore : manages
AssessmentResultRepository ..> AssessmentResult : manages

@enduml
