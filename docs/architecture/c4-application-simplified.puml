@startuml Guardian Application Layer
top to bottom direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam class {
    BackgroundColor White
    BorderColor Black
}

package "Services" {
    class AuthService {
        -userRepository: IUserRepository
        -tokenProvider: ITokenProvider
        +authenticate(email, password): AuthResult
        +createUser(dto: CreateUserDTO): User
        +validateToken(token): TokenPayload
    }

    class ConversationService {
        -conversationRepo: IConversationRepository
        -messageRepo: IMessageRepository
        -claudeClient: IClaudeClient
        +create(dto: CreateConversationDTO): Conversation
        +sendMessage(dto: SendMessageDTO): Message
        +getHistory(conversationId): Message[]
        +switchMode(conversationId, mode): void
        +updateTitle(conversationId, title): void
    }

    class AssessmentService {
        -assessmentRepo: IAssessmentRepository
        -vendorRepo: IVendorRepository
        +create(dto: CreateAssessmentDTO): Assessment
        +updateStatus(id, status): void
        +getByVendor(vendorId): Assessment[]
        +markScored(id): void
    }

    class VendorService {
        -vendorRepo: IVendorRepository
        +create(name, industry): Vendor
        +update(id, data): Vendor
        +list(): Vendor[]
    }

    class QuestionnaireGenerationService {
        -claudeClient: IClaudeClient
        -questionRepo: IQuestionRepository
        +generate(assessmentId, context): Question[]
        +parseQuestions(rawOutput): Question[]
    }

    class QuestionnaireReadyService {
        -assessmentService: AssessmentService
        -vendorService: VendorService
        +checkReadiness(conversationId): ReadinessResult
        +getVendorContext(): VendorContext
    }

    class ScoringService {
        -claudeClient: IClaudeClient
        -validator: ScoringPayloadValidator
        -resultRepo: IAssessmentResultRepository
        -dimensionRepo: IDimensionScoreRepository
        +scoreAssessment(assessmentId): ScoringResult
        +streamProgress(callback): void
        +persistResults(result): void
    }

    class ScoringExportService {
        -scoringService: ScoringService
        -pdfExporter: ScoringPDFExporter
        -wordExporter: ScoringWordExporter
        +exportToPDF(assessmentId): Buffer
        +exportToWord(assessmentId): Buffer
    }

    class ExportService {
        -pdfExporter: IPDFExporter
        -wordExporter: IWordExporter
        -excelExporter: IExcelExporter
        +exportToPDF(assessmentId): Buffer
        +exportToWord(assessmentId): Buffer
        +exportToExcel(assessmentId): Buffer
    }

    class FileValidationService {
        +validateFile(file): ValidationResult
        +getAllowedTypes(): string[]
        +getMaxSize(): number
    }

    class OrphanCleanupService {
        -responseRepo: IResponseRepository
        +cleanupOrphanedResponses(cutoff): number
        +scheduleCleanup(): void
    }

    class TitleGenerationService {
        -claudeClient: IClaudeClient
        +generateTitle(messages): string
        +shouldUpdateTitle(conversation): boolean
    }
}

package "DTOs" {
    class CreateUserDTO {
        +email: string
        +name: string
        +password: string
    }

    class CreateAssessmentDTO {
        +vendorId: string
        +assessmentType: string
        +solutionName: string
    }

    class CreateConversationDTO {
        +userId: string
        +mode: ConversationMode
        +assessmentId?: string
    }

    class SendMessageDTO {
        +conversationId: string
        +content: string
        +attachments?: FileAttachment[]
    }

    class ScoringResultDTO {
        +compositeScore: number
        +recommendation: Recommendation
        +overallRiskRating: RiskRating
        +dimensionScores: DimensionScoreDTO[]
    }
}

package "Interfaces (Ports)" {
    interface IUserRepository {
        +findById(id): User
        +findByEmail(email): User
        +save(user): User
    }

    interface IConversationRepository {
        +findById(id): Conversation
        +findByUserId(userId): Conversation[]
        +save(conversation): Conversation
        +updateTitle(id, title, manual): void
    }

    interface IAssessmentRepository {
        +findById(id): Assessment
        +findByVendorId(vendorId): Assessment[]
        +save(assessment): Assessment
    }

    interface IResponseRepository {
        +findByAssessmentId(id): Response[]
        +saveBatch(responses): void
        +deleteOrphans(cutoff): number
    }

    interface IDimensionScoreRepository {
        +findByAssessmentId(id): DimensionScore[]
        +saveBatch(scores): void
    }

    interface IAssessmentResultRepository {
        +findByAssessmentId(id): AssessmentResult
        +save(result): AssessmentResult
        +claimNarrativeGeneration(id): boolean
    }

    interface IClaudeClient {
        +chat(messages): Response
        +streamChat(messages, callback): void
        +streamMessage(messages, options, imageBlocks?): AsyncGenerator
        +useTools(messages, tools): ToolResult
    }

    interface IVisionContentBuilder {
        +buildImageContent(file, conversationId?): ImageContentBlock
        +isImageFile(mimeType): boolean
        +clearConversationCache(conversationId): void
    }

    interface ITokenProvider {
        +sign(payload): string
        +verify(token): TokenPayload
    }

    interface IPDFExporter {
        +generate(data): Buffer
    }
}

' Service dependencies on interfaces
AuthService --> IUserRepository
AuthService --> ITokenProvider
ConversationService --> IConversationRepository
ConversationService --> IClaudeClient
AssessmentService --> IAssessmentRepository
ScoringService --> IClaudeClient
ScoringService --> IAssessmentResultRepository
ScoringService --> IDimensionScoreRepository
QuestionnaireGenerationService --> IClaudeClient
ExportService --> IPDFExporter
OrphanCleanupService --> IResponseRepository
TitleGenerationService --> IClaudeClient

' Services use DTOs
AuthService ..> CreateUserDTO : uses
AssessmentService ..> CreateAssessmentDTO : uses
ConversationService ..> CreateConversationDTO : uses
ConversationService ..> SendMessageDTO : uses
ScoringService ..> ScoringResultDTO : produces

' Service to service dependencies
ConversationService --> AssessmentService : uses
QuestionnaireGenerationService --> AssessmentService : uses
QuestionnaireReadyService --> AssessmentService : uses
QuestionnaireReadyService --> VendorService : uses
ScoringService --> AssessmentService : uses
ScoringExportService --> ScoringService : uses
ConversationService --> TitleGenerationService : uses

@enduml
